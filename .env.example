# MGCompliance Environment Configuration
# Copy to .env and fill in values

# Flask
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Database (PostgreSQL) — used when connecting to an external database.
# When using docker-compose.yml, the DATABASE_URL is set automatically.
DATABASE_URL=postgresql://mgcompliance:mgcompliance@localhost:5432/mgcompliance

# PostgreSQL container settings (used by docker-compose.yml)
POSTGRES_DB=mgcompliance
POSTGRES_USER=mgcompliance
POSTGRES_PASSWORD=mgcompliance

# Portal branding — customize for your organization
PORTAL_COMPANY_NAME=Your Company
PORTAL_BRAND_NAME=Your Brand
PORTAL_CONTACT_EMAIL=compliance@example.com

# Port mapping (host port for docker-compose)
PORT=5100

# AWS evidence collection (optional — leave blank to skip)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GitHub evidence collection (optional — leave blank to skip)
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_API_URL=https://api.github.com
GITHUB_REPOS=

# TrustCloud migration (optional — only needed during initial data import)
TRUSTCLOUD_API_KEY=

# SessionEnd hook configuration (set on developer workstations)
# The hook POSTs session transcripts to the trust portal for compliance audit trail.
MGCOMPLIANCE_API_URL=https://trust.example.com
MGCOMPLIANCE_API_KEY=
