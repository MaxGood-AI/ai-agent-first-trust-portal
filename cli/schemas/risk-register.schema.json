{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Risk Register Data File",
  "description": "Risk register entries. Array of risk objects loaded by `cli init --data-dir`.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name"],
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "name": { "type": "string" },
      "description": { "type": "string" },
      "likelihood": { "type": "integer", "minimum": 1, "maximum": 5 },
      "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
      "risk_score": { "type": "number" },
      "treatment": { "type": "string", "enum": ["accept", "mitigate", "transfer", "avoid"] },
      "treatment_plan": { "type": "string" },
      "status": { "type": "string", "enum": ["open", "mitigated", "accepted", "closed"] },
      "owner": {
        "type": "object",
        "properties": {
          "id": { "type": ["string", "null"], "format": "uuid" },
          "name": { "type": "string" }
        }
      },
      "group_name": { "type": "string" },
      "review_date": { "type": "string", "format": "date" }
    }
  }
}
